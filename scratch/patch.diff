+<script>
+    async function loadRequestData() {
+        const urlParams = new URLSearchParams(window.location.search);
+        const itemId = urlParams.get('itemId');
+        
+        if (!itemId) return;
+        
+        try {
+            const item = await window.db.getItem(itemId);
+            if (!item) return;
+            
+            const ownerName = item.profiles?.full_name || 'The owner';
+            const firstName = ownerName.split(' ')[0];
+            
+            document.getElementById('success-message').innerHTML = `${ownerName} has been notified. We'll let you know once they approve your request for the <span class="font-semibold text-primary">${item.name}</span>.`;
+            document.getElementById('step-1-desc').textContent = `${firstName} confirms the dates and availability of the item.`;
+            document.getElementById('step-2-desc').textContent = `You'll be able to message ${firstName} to coordinate the handoff and pickup location.`;
+        } catch (err) {
+            console.error("Error loading item for request success:", err);
+        }
+    }
+    document.addEventListener('DOMContentLoaded', loadRequestData);
+</script>
